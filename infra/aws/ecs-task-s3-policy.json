{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PrivacyToolboxS3Objects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::REPLACE_BUCKET_NAME/*"
    },
    {
      "Sid": "PrivacyToolboxS3ListLimited",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::REPLACE_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["uploads/*", "outputs/*", "reports/*", "tmp/*"]
        }
      }
    }
  ]
}
