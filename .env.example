# Development defaults. Copy to .env for local testing.
APP_ENV=development
SECRET_KEY=replace-this-with-a-long-random-secret-minimum-32-characters
SITE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/privacy-toolbox
STORAGE_BACKEND=local
DATABASE_URL=
USER_STORAGE_BACKEND=json
QUOTA_BACKEND=local
AWS_REGION=ap-south-1
S3_BUCKET=
S3_UPLOAD_PREFIX=uploads/
S3_OUTPUT_PREFIX=outputs/
S3_REPORT_PREFIX=reports/

# Celery queue separation. Lightsail uses one worker listening to all queues; ECS can split workers.
CELERY_DEFAULT_QUEUE=default
CELERY_LIGHT_QUEUE=light
CELERY_HEAVY_QUEUE=heavy
CELERY_WORKER_QUEUES=light,heavy,default,celery
WORKER_SOFT_TIME_LIMIT_SECONDS=1080
WORKER_HARD_TIME_LIMIT_SECONDS=1200
MAX_UPLOAD_MB=512
DOWNLOAD_TOKEN_TTL_MINUTES=10
JOB_TTL_MINUTES=60
RATE_LIMIT_PER_MINUTE=45
AUTH_COOKIE_NAME=pt_session
AUTH_COOKIE_SECURE=false
UPLOAD_SESSION_COOKIE_NAME=pt_upload_session
CSRF_COOKIE_NAME=pt_csrf
ADMIN_DASHBOARD_PATH=/dashboard

ZIP_MAX_ENTRY_MB=256
ZIP_MAX_TOTAL_UNCOMPRESSED_MB=1024
ZIP_MAX_COMPRESSION_RATIO=80
ZIP_MAX_DEPTH=10

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=gulimran980@gmail.com
SMTP_FROM_NAME=Privacy Toolbox
SMTP_USE_TLS=true
CONTACT_ADMIN_EMAIL=gulimran980@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
REQUIRE_SMTP_IN_PRODUCTION=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/oauth/microsoft/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
REQUIRE_OAUTH_PROVIDERS_IN_PRODUCTION=true
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_PATH=/dashboard?billing=success
STRIPE_CANCEL_PATH=/pricing?billing=cancelled
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_PRICE_ID_TEAM_YEARLY=
STRIPE_PRICE_ID_BUSINESS_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_YEARLY=

C2PATOOL_SHA256=
