# Production example for low-cost AWS Lightsail/EC2 Docker deployment.
# Copy to .env.production and change every secret/domain before deploying.

APP_ENV=production
SECRET_KEY=CHANGE_TO_64_CHAR_RANDOM_SECRET

# Use one domain through Caddy to reduce cost and avoid an AWS load balancer.
SITE_DOMAIN=your-domain.com
CORS_ORIGINS=https://your-domain.com
FRONTEND_URL=https://your-domain.com
API_PUBLIC_URL=https://your-domain.com
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/privacy-toolbox
STORAGE_BACKEND=local
DATABASE_URL=
USER_STORAGE_BACKEND=json
QUOTA_BACKEND=local
AWS_REGION=ap-south-1
S3_BUCKET=
S3_UPLOAD_PREFIX=uploads/
S3_OUTPUT_PREFIX=outputs/
S3_REPORT_PREFIX=reports/

# Celery queue separation. Lightsail uses one worker listening to all queues; ECS can split workers.
CELERY_DEFAULT_QUEUE=default
CELERY_LIGHT_QUEUE=light
CELERY_HEAVY_QUEUE=heavy
CELERY_WORKER_QUEUES=light,heavy,default,celery
WORKER_SOFT_TIME_LIMIT_SECONDS=1080
WORKER_HARD_TIME_LIMIT_SECONDS=1200

# Cost-control defaults. Raise only after increasing worker memory/storage.
MAX_UPLOAD_MB=512
DOWNLOAD_TOKEN_TTL_MINUTES=10
JOB_TTL_MINUTES=60
RATE_LIMIT_PER_MINUTE=45
AUTH_COOKIE_NAME=pt_session
AUTH_COOKIE_SECURE=true
UPLOAD_SESSION_COOKIE_NAME=pt_upload_session
CSRF_COOKIE_NAME=pt_csrf
ADMIN_DASHBOARD_PATH=/dashboard

# ZIP/OOXML safety controls for low-cost single-server processing.
ZIP_MAX_ENTRY_MB=256
ZIP_MAX_TOTAL_UNCOMPRESSED_MB=1024
ZIP_MAX_COMPRESSION_RATIO=80
ZIP_MAX_DEPTH=10

# Docker resource knobs for AWS 4GB RAM / 2 vCPU profile.
API_WORKERS=1
WORKER_CONCURRENCY=1
WORKER_MAX_TASKS_PER_CHILD=20
REDIS_MAXMEMORY=256mb
API_MEM_LIMIT=768m
WORKER_MEM_LIMIT=1536m
WEB_MEM_LIMIT=512m
BEAT_MEM_LIMIT=256m
CADDY_MEM_LIMIT=256m
API_CPUS=0.75
WORKER_CPUS=1.0
WEB_CPUS=0.50
BEAT_CPUS=0.20
API_TMPFS_SIZE=512m
WORKER_TMPFS_SIZE=1024m

# Explicit admin bootstrap. Public signup never creates an admin.
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_TO_14_PLUS_CHAR_RANDOM_PASSWORD

# Transactional email for verification and contact notifications.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_FROM_NAME=Privacy Toolbox
SMTP_USE_TLS=true
CONTACT_ADMIN_EMAIL=admin@your-domain.com
VERIFICATION_CODE_TTL_MINUTES=15
REQUIRE_SMTP_IN_PRODUCTION=true

# OAuth providers. Add credentials later; buttons safely redirect with a setup message until configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-domain.com/api/auth/oauth/microsoft/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
REQUIRE_OAUTH_PROVIDERS_IN_PRODUCTION=true
GITHUB_REDIRECT_URI=https://your-domain.com/api/auth/oauth/github/callback

# Stripe billing. Leave empty for now; checkout/webhook stay disabled safely.
# After creating Stripe products/prices, add the keys and price IDs, then rebuild/restart.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_PATH=/dashboard?billing=success
STRIPE_CANCEL_PATH=/pricing?billing=cancelled
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_PRICE_ID_TEAM_YEARLY=
STRIPE_PRICE_ID_BUSINESS_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_YEARLY=

# Supply-chain verification for c2patool production Docker builds.
# Fill with official tarball SHA256 for c2patool-v0.26.59-x86_64-unknown-linux-gnu.tar.gz.
C2PATOOL_SHA256=
